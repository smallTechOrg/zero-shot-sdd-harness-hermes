# ---- Full Stack Analytics Agent ----
# Copy this file to `.env` and fill in what you have. Nothing is required for
# Phase 1 — without keys the dashboard runs fully on the SAMPLE adapter.
# Copy:  cp .env.example .env

# Server
PORT=8001
DATABASE_URL=sqlite:///./analytics.db

# LLM (OpenRouter) — OPTIONAL in Phase 1.
# Without it, the insight panel shows a clearly-labelled SAMPLE summary.
AGENT_OPENROUTER_API_KEY=
ANALYTICS_LLM_MODEL=anthropic/claude-sonnet-4-6

# Connectors — all optional in Phase 1. Each lights up when its key is set.
# Phase 2 makes these live.
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=
BUSINESS_DB_URL=
PLAY_STORE_CREDENTIALS_JSON=
APPSTORE_CONNECT_KEY_ID=
APPSTORE_CONNECT_ISSUER_ID=
APPSTORE_CONNECT_PRIVATE_KEY_P8=
INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=

# Observability
LOG_LEVEL=INFO
