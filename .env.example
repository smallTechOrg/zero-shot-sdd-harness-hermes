AGENT_DATABASE_URL=sqlite:///./data/agent.db

# LLM provider — auto-detected from whichever key is set below.
# Override explicitly: anthropic | gemini
# AGENT_LLM_PROVIDER=gemini

# Override model (verified against the live ListModels whitelist on this account).
# AGENT_LLM_MODEL=gemini-3.1-pro-preview       (Gemini default on this account)
# Other 3.x options available: gemini-3-pro-preview, gemini-3-flash-preview, gemini-3.5-flash

# Set exactly ONE provider key:
AGENT_ANTHROPIC_API_KEY=
AGENT_GEMINI_API_KEY=

# MSSQL source (read-only analyst) — Windows Integrated Auth
# AGENT_MSSQL_HOST=localhost
# AGENT_MSSQL_DB=master
# AGENT_MSSQL_DRIVER=ODBC Driver 17 for SQL Server
# AGENT_MSSQL_INTEGRATED_AUTH=true
# AGENT_MSSQL_USER=
# AGENT_MSSQL_PASSWORD=

PORT=8001
