# ===========================================================================
# Data Analyst Agent — environment template
# Copy to .env and fill in. Never commit .env (it holds secrets).
# ===========================================================================

# ---- MsSQL connection (read-only access enforced at the app layer) ----
# Phase 1 uses Azure SQL Edge in Docker (real Microsoft SQL engine).
# Swap this for your 8 TB warehouse connection string in production.
AGENT_DATABASE_URL=Server=localhost,1433;Database=WarehouseDemo;User Id=sa;Password=Str0ngP@ssw0rd!;TrustServerCertificate=True;Connection Timeout=30;

# ---- LLM provider (OpenRouter — any model, one key) ----
# Raw data rows NEVER leave the server: only the warehouse schema + aggregate
# profile metadata are sent to the LLM for SQL generation.
AGENT_LLM_PROVIDER=openrouter
AGENT_OPENROUTER_API_KEY=
# Cheap, fast default; override as needed (must be a valid OpenRouter slug):
AGENT_LLM_MODEL=google/gemini-3.5-flash

# ---- App ----
PORT=8001
# Reject any generated SQL containing these tokens (belt-and-suspenders read-only):
# (comma-separated; empty = use built-in deny list)
SQL_DENY_TOKENS=
