# Environment variables for UP Police Data Analyst Agent

# Database URL for SQLite metadata (local file)
DATABASE_URL=sqlite:///./data/agent.db

# Parquet cache directory (local filesystem)
# Optional: if not set, defaults to ./data/cache
# PARQUET_CACHE_DIR=./data/cache

# OpenRouter API key (required for LLM)
OPENROUTER_API_KEY=

# Optional: override model (defaults to a free model if not set)
# OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# Server port
PORT=8001