# Auto-Podcaster — environment variables (app)
# Copy this file to .env and fill in your keys. .env is gitignored; never commit it.
# The app loads the repo-root .env via python-dotenv — do NOT create a second .env elsewhere.

# LLM provider for conversation generation (REQUIRED to run).
# Used by src/graph/dialogue.py via google-generativeai.
AGENT_GEMINI_API_KEY=

# TTS provider: Phase 1 uses edge-tts, which is FREE and needs NO API key.
# Distinct per-host voices are configured in src/prompts.py. No env var required.
# (If you later swap to a paid TTS, document its key here.)
